generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum FieldStage {
  PLANTED
  GROWING
  READY
  HARVESTED
}

model User {
  id       String    @id @default(uuid())
  name     String
  email    String    @unique
  password String
  role     Role      @default(AGENT)
  fields   Field[]   @relation("AssignedFields")
  updates  FieldUpdate[]
}

model Field {
  id              String        @id @default(uuid())
  name            String
  cropType        String
  plantingDate    DateTime
  stage           FieldStage
  assignedAgentId String?
  agent           User?         @relation("AssignedFields", fields: [assignedAgentId], references: [id])
  updates         FieldUpdate[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model FieldUpdate {
  id        String     @id @default(uuid())
  note      String
  stage     FieldStage
  fieldId   String
  field     Field      @relation(fields: [fieldId], references: [id])
  agentId   String
  agent     User       @relation(fields: [agentId], references: [id])
  createdAt DateTime   @default(now())
}
